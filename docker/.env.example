# BabyGuardian Docker Environment Configuration

# ==================== NGINX / SSL ====================

# Domain for the application (must match DNS records)
SSL_DOMAIN=babyguardian.golinkia.com

# Email for Let's Encrypt SSL certificate notifications
# If empty, will use self-signed certificates (development only)
# For production, use a valid email: SSL_EMAIL=admin@example.com
SSL_EMAIL=

# ==================== BACKEND / NODE ====================

# Node environment
NODE_ENV=production

# JWT Configuration
# Generate a long random string: openssl rand -base64 32
JWT_SECRET=change_this_to_a_very_long_random_secret_in_production

# JWT token expiration time
JWT_EXPIRES_IN=7d

# ==================== DATABASE ====================

# PostgreSQL connection string (internal Docker network)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://babyguardian:babyguardian_secret_2024@postgres:5432/babyguardian

# ==================== CACHE ====================

# Redis connection string (internal Docker network)
REDIS_URL=redis://redis:6379

# ==================== EXTERNAL SERVICES ====================

# Firebase Cloud Messaging (for push notifications)
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key

# Google OAuth Client ID (for Google Sign-In)
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Groq API (optional - for AI features)
GROQ_API_KEY=

# OpenAI API Key (optional - for AI features)
OPENAI_API_KEY=

# Anthropic API Key (optional - for AI features)
ANTHROPIC_API_KEY=

# ==================== AI MODELS ====================

# Which model to use for Groq
GROQ_MODEL=llama-3.1-70b-versatile

# Which model to use for OpenAI
OPENAI_MODEL=gpt-4o-mini

# Which model to use for Anthropic
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
