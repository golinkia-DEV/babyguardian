# Development Environment for Mobile App

# For emulator/local development:
# REACT_NATIVE_API_URL=http://10.0.2.2:3000/api/v1

# For production/remote server:
REACT_NATIVE_API_URL=https://babyguardian.golinkia.com/api/v1

# Google OAuth
REACT_NATIVE_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com

# Dev mode (bypass auth for testing)
REACT_NATIVE_AUTH_DEV_BYPASS=false
