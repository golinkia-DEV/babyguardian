NODE_ENV=development
# Solo desarrollo: sin header Authorization, la API actúa como el usuario con UUID indicado (debe existir en `users`).
AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS_USER_ID=
# Hub debug: en apps/hub/local.properties → dev.skip.auth=true (requiere líneas anteriores).
# Móvil: REACT_NATIVE_AUTH_DEV_BYPASS=true en el env de Metro (misma API).
PORT=3000
DATABASE_URL=postgresql://babyguardian:babyguardian_dev_2024@localhost:5432/babyguardian_dev
REDIS_URL=redis://localhost:6379
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
# Opcional: clave dedicada para credenciales de cámaras (AES-256-GCM). Si no se define, se deriva de JWT_SECRET (solo desarrollo).
CAMERA_ENCRYPTION_KEY=
FCM_SERVER_KEY=your_firebase_cloud_messaging_server_key
# Mismo ID de cliente OAuth "Web" que en Hub Android: apps/hub/app/src/main/res/values/strings.xml → default_web_client_id
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
CORS_ORIGINS=http://localhost:8081,http://localhost:3001

# IA (chat en servidor; el móvil no guarda API keys)
GROQ_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
