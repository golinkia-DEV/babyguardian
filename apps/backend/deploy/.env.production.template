# =============================================================================
# BabyGuardian Backend - Plantilla de variables de entorno para produccion
# =============================================================================
# Instrucciones:
#   1. Copia este archivo: cp .env.production.template /opt/babyguardian/backend/.env
#   2. Rellena TODOS los campos marcados con <CHANGE_ME>
#   3. Asegura permisos: chmod 600 /opt/babyguardian/backend/.env
#   4. NUNCA subas el .env real a git (.gitignore ya lo excluye)
# =============================================================================

# ---- Entorno ----------------------------------------------------------------
NODE_ENV=production
PORT=3000

# ---- Base de datos ----------------------------------------------------------
# El valor exacto lo imprime deploy/setup-db.sh al ejecutarse
DATABASE_URL=postgresql://babyguardian:<CHANGE_ME>@localhost:5432/babyguardian_prod

# ---- JWT --------------------------------------------------------------------
# Genera con: openssl rand -hex 64
JWT_SECRET=<CHANGE_ME>
JWT_EXPIRES_IN=7d

# ---- Redis (opcional; comentar si no usas cache/sesiones) -------------------
# REDIS_URL=redis://localhost:6379

# ---- CORS -------------------------------------------------------------------
# Origenes permitidos separados por coma.
# Usa '*' solo en desarrollo o apps moviles sin dominio fijo.
# En produccion web pon el dominio real: https://babyguardian.golinkia.com
CORS_ORIGINS=*

# ---- Auth dev bypass (NUNCA activar en produccion) -------------------------
AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS_USER_ID=

# ---- Google OAuth -----------------------------------------------------------
# https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_ID=<CHANGE_ME>

# ---- Firebase Cloud Messaging (notificaciones push) ------------------------
# https://console.firebase.google.com -> Project Settings -> Cloud Messaging
FCM_SERVER_KEY=<CHANGE_ME>

# ---- Cifrado camara ---------------------------------------------------------
# Clave AES para URLs cifradas de camaras
# Genera con: openssl rand -hex 32
CAMERA_ENCRYPTION_KEY=<CHANGE_ME>

# ---- IA — al menos uno de los tres debe estar configurado ------------------

# Groq (rapido, gratuito con limites): https://console.groq.com
GROQ_API_KEY=<CHANGE_ME>
GROQ_MODEL=llama-3.1-70b-versatile

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Anthropic: https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
