# =============================================================================
# BabyGuardian Backend - Variables de entorno PRODUCCION
# Copia como /opt/babyguardian/backend/.env y completa los valores reales
# =============================================================================

NODE_ENV=production

# ---- App ----
PORT=3000

# ---- CORS: '*' acepta cualquier origen (app local / LAN) ----
CORS_ORIGINS=*

# ---- Auth (NO activar en produccion) ----
AUTH_DEV_BYPASS=false
AUTH_DEV_BYPASS_USER_ID=

# ---- JWT (genera con: openssl rand -hex 64) ----
JWT_SECRET=CAMBIAR_POR_SECRET_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=7d

# ---- PostgreSQL ----
# Reemplaza con el password generado por setup-db.sh
DATABASE_URL=postgresql://babyguardian:TU_PASSWORD_AQUI@localhost:5432/babyguardian_prod

# ---- Redis (opcional; comentar si no se usa) ----
# REDIS_URL=redis://localhost:6379

# ---- Cifrado de credenciales de camara (genera: openssl rand -hex 32) ----
CAMERA_ENCRYPTION_KEY=CAMBIAR_POR_CLAVE_AES_32_BYTES_HEX

# ---- Firebase Cloud Messaging (notificaciones push) ----
FCM_SERVER_KEY=

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=

# ---- IA (al menos uno requerido si se usa el modulo AI) ----
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-70b-versatile

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022
