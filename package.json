{
  "name": "babyguardian-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/backend",
    "packages/*"
  ],
  "scripts": {
    "backend:dev": "cd apps/backend && npm run start:dev",
    "docker:dev": "cd docker && docker compose -f docker-compose.dev.yml up -d",
    "docker:down": "cd docker && docker compose -f docker-compose.dev.yml down",
    "docker:prod": "cd docker && docker compose up -d",
    "mobile:android": "cd apps/mobile && npx react-native run-android",
    "mobile:ios": "cd apps/mobile && npx react-native run-ios"
  }
}
